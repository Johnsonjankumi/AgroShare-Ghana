# Backend production environment variables
# Copy to backend/.env.production and replace every placeholder value.

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
ENVIRONMENT=production

# Render frontend domain(s)
CORS_ORIGINS=https://agroshare-frontend.onrender.com

# Render PostgreSQL connection string
DATABASE_URL=postgresql://username:password@db-host:5432/agroshare

# Render backend JWT secret
JWT_SECRET=replace-this-with-a-long-random-secret