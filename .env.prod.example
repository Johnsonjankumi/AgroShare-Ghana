# Root production environment file for docker-compose.prod.yml
# Copy this file to .env in the repository root before running the production stack.

# Full hosted PostgreSQL connection string
DATABASE_URL=postgresql://username:password@db-host:5432/agroshare

# Render frontend domain(s) allowed by backend CORS
CORS_ORIGINS=https://agroshare-frontend.onrender.com

# Long random backend secret
JWT_SECRET=replace-this-with-a-long-random-secret

# Render backend API URL used by the frontend build
REACT_APP_API_BASE=https://agroshare-api.onrender.com/api
